{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Moodcrate",
  "version": "1.3.2",
  "identifier": "com.sebastien.moodcrate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Moodcrate",
        "width": 1024,
        "height": 720,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks.nsi"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMzNUZBMjA4QkExNjA3NEIKUldSTEJ4YTZDS0pmTXl4VFBTL2xSaW13KzdTS0ZHMDk4Vk5mYTBXYmFZREVYcHBEcjBGbFpUVEgK",
      "endpoints": [
        "https://github.com/CGSeb/moodcrate/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
